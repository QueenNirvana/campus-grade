<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.campusgrade.mapper.UserMapper">
    <select id="findAll" resultType="com.example.campusgrade.entity.User">
        SELECT * FROM users ORDER BY id DESC
    </select>
    <select id="findById" resultType="com.example.campusgrade.entity.User">
        SELECT * FROM users WHERE id = #{id}
    </select>
    <select id="findByUsername" resultType="com.example.campusgrade.entity.User">
        SELECT * FROM users WHERE username = #{username}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users(username, password, real_name, role, status)
        VALUES(#{username}, #{password}, #{realName}, #{role}, #{status})
    </insert>
    <update id="update">
        UPDATE users
        SET username=#{username}, real_name=#{realName}, role=#{role}, status=#{status}
        <if test="password != null and password != ''">, password=#{password}</if>
        WHERE id=#{id}
    </update>
    <delete id="delete">
        DELETE FROM users WHERE id=#{id}
    </delete>
    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM users
    </select>
</mapper>
