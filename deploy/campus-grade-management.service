[Unit]
Description=Campus Grade Management Spring Boot Backend
After=network.target mysql.service

[Service]
Type=simple
WorkingDirectory=/opt/campus-grade-management/backend
EnvironmentFile=/opt/campus-grade-management/.env
ExecStart=/usr/bin/java -jar /opt/campus-grade-management/backend/campus-grade-management-0.0.1-SNAPSHOT.jar
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
